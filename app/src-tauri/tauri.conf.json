{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XiaoAi Control PC",
  "version": "1.0.0",
  "identifier": "com.fyk.xiaoaicontrolpc",
  "build": {
    "beforeBuildCommand": "npm run prepare-app-assets",
    "beforeDevCommand": "npm run prepare-app-assets",
    "frontendDist": "../desktop"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "XiaoAi Control PC",
        "width": 960,
        "height": 540,
        "resizable": true,
        "maximizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "resources": [
      "resources/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
